# IDE / agent — local only; repo must stay modpack + docs (README, CHANGELOG, etc.)
.cursor/
.agent/

# Local benchmark exports (HWiNFO, Spark .sparkprofile) — machine-specific
logs/

# Sodium writes this per machine when the game runs — do not commit
config/sodium-fingerprint.json

# Local Notion API credentials for the official integration
.env
.env.example
.env.local

# Python helper script cache
__pycache__/
*.pyc

# Ignore only mods themselves, not their metadata
mods/*.jar
!mods/*.pw.toml
*.jar
!packwiz-installer-bootstrap.jar
